# Auto detect text files and normalize line endings
* text=auto

# R scripts always use LF
*.R text eol=lf
*.r text eol=lf

# Shell scripts always use LF
*.sh text eol=lf
*.slurm text eol=lf

# Markdown
*.md text eol=lf

# Python
*.py text eol=lf

# Keep binary files as-is
*.png binary
*.pdf binary
*.rds binary
*.RData binary
*.rda binary
